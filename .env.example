# =====================================
# MySQL Database 설정
# =====================================
DB_HOST=localhost           # DB 서버 호스트
DB_PORT=3306                # DB 포트
DB_NAME=backend_db          # DB 이름
DB_USERNAME=backend_user    # DB 사용자
DB_PASSWORD=secret_password # DB 비밀번호

# =====================================
# Redis 서버 설정
# =====================================
REDIS_HOST=localhost        # Redis 서버 호스트
REDIS_PORT=6379             # Redis 포트
REDIS_PASSWORD=             # Redis 비밀번호 (없으면 빈 값)

# =====================================
# JWT 설정
# =====================================
JWT_ACCESS_SECRET=yourAccessTokenSecretKeyHere   # 충분히 긴 랜덤 문자열
JWT_REFRESH_SECRET=yourRefreshTokenSecretKeyHere # 충분히 긴 랜덤 문자열

# =====================================
# Cookie 설정
# =====================================
COOKIE_DOMAIN=localhost     # 쿠키 도메인 (예: localhost, example.com)
COOKIE_SECURE=false         # HTTPS 사용 시 true
COOKIE_SAME_SITE=Lax        # Lax / Strict / None

# =====================================
# AWS S3 설정
# =====================================
BUCKET_NAME=your-test-bucket  # S3 버킷 이름
REGION=your-region            # S3 리전

# =====================================
# CORS 허용 Origin
# =====================================
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000
